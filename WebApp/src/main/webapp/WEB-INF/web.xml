<?xml version="1.0" encoding="UTF-8"?>

<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Food Delivery Order Management System</display-name>
    <description>Online Food Delivery Order Tracker Web Application</description>

    <!-- Welcome Page -->
    <welcome-file-list>
        <welcome-file>login.jsp</welcome-file>
    </welcome-file-list>

    <!-- Session Config -->
    <session-config>
        <cookie-http-only>true</cookie-http-only>
        <tracking-mode>COOKIE</tracking-mode>
        <timeout-in-minutes>30</timeout-in-minutes>
    </session-config>

    <!-- Session Check Filter -->
    <filter>
        <filter-name>SessionCheckFilter</filter-name>
        <filter-class>com.fooddelivery.servlet.SessionCheckFilter</filter-class>
    </filter>

    <filter-mapping>
        <filter-name>SessionCheckFilter</filter-name>
        <url-pattern>/dashboard</url-pattern>
    </filter-mapping>

    <filter-mapping>
        <filter-name>SessionCheckFilter</filter-name>
        <url-pattern>/viewOrders</url-pattern>
    </filter-mapping>

    <!-- NOTE: Servlet mappings are defined via @WebServlet annotations in the servlet classes -->
    <!-- Do NOT add servlet-mapping here to avoid conflicts with annotations in Tomcat 10+ -->

</web-app>
